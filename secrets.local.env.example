# Web Scraping Email Configuration
# Copy this file to secrets.local.env and fill in your values
# Then update SECRETS_ENV_PATH in config.py to point to your file

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
USE_SSL=false
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
RECEIVER_EMAILS=recipient1@gmail.com,recipient2@example.com
